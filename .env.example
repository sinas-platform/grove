# Grove backend
GROVE_DATABASE_URL=postgresql+asyncpg://grove:grove@localhost:5432/grove
GROVE_PORT=8080
GROVE_LOG_LEVEL=INFO
GROVE_CORS_ORIGINS=http://localhost:5173

# Auth mode:
#   sinas       — per-user: backend validates the caller's Sinas bearer token
#                 via /auth/me on every request, uses that token for callbacks
#   simplified  — single-key: backend uses SINAS_API_KEY for ALL Sinas
#                 callbacks; the user owning that key is the admin
GROVE_AUTH_MODE=simplified

# Sinas instance Grove talks to
SINAS_URL=http://localhost:8000

# Required when GROVE_AUTH_MODE=simplified. Resolved once via /auth/me to
# derive the admin user id (no separate owner-id env var needed).
SINAS_API_KEY=
